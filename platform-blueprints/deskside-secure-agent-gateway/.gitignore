# Test output — never commit run artifacts
artifacts/

# Python venvs created by test runners
*-venv/

# Temp Claude Code settings files written by claude_job.sh
/tmp/cc-settings-*.json

# Node deps
node_modules/

# The repo-root .gitignore has a Python-template `lib/` rule that also matches
# tests/lib/, so re-include them.
!tests/lib/
!tests/lib/*.sh
